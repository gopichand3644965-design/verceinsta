{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["data/**", "public/**", "auth/**"]
      }
    }
  ],
  "routes": [
    {
      "src": "/assets/banners/(.*)",
      "headers": {
        "Access-Control-Allow-Origin": "*"
      },
      "dest": "/public/assets/banners/$1"
    },
    {
      "src": "/(.*)",
      "headers": {
        "Access-Control-Allow-Origin": "*",
        "Access-Control-Allow-Methods": "GET,OPTIONS,PATCH,DELETE,POST,PUT",
        "Access-Control-Allow-Headers": "X-CSRF-Token, X-Customer-Token, X-Requested-With, Accept, Accept-Version, Content-Length, Content-MD5, Content-Type, Date, X-Api-Version, Authorization"
      },
      "dest": "server.js"
    }
  ]
}
