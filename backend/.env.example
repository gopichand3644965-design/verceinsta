# Supabase Configuration
# Get these values from your Supabase project settings (https://supabase.com)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-anonymous-key-here

# Backend Port
PORT=4000

# Note: Before using Supabase, you must:
# 1. Create a Supabase project at https://supabase.com
# 2. Create a "products" table with columns:
#    - id (text, primary key)
#    - data (jsonb)
# 3. Copy your project URL and anonymous key to this file
# 4. Rename this file to .env
